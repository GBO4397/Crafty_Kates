# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed to source control.

# ── Supabase ────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Admin access ────────────────────────────────────────────────────
# Used as a client-side fallback when the verify-admin edge function
# is not deployed. For production, deploy the edge function and remove
# this variable — the password will NOT be in the edge function bundle.
VITE_ADMIN_PASSWORD=your-admin-password-here
